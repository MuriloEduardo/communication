    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: HTTP Server",
            "type": "debugpy",
            "request": "launch",
            "module": "app.main",
            "args": [
                "--http"
            ],
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Python: All Workers",
            "type": "debugpy",
            "request": "launch",
            "module": "app.main",
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Python: Send Message Worker",
            "type": "debugpy",
            "request": "launch",
            "module": "app.main",
            "args": [
                "--workers",
                "send_message"
            ],
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python"
        }
    ]
}